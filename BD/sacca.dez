<TRIGGERS>
<TRIGGER>
<NAME>TI_MOVIMIENTOS</NAME>
<ID>2</ID>
<POSNR>0</POSNR>
<SCHEMA></SCHEMA>
<DESC></DESC>
<NOTE></NOTE>
<CODE>Create  TRIGGER %triggername% ON %tablename%
FOR INSERT

AS
declare @v_saldo  numeric(10,2)
declare @v_monto  numeric(10,2)
declare @V_ID_INTERFAZ  int
declare @v_ID_CUENTA_CORRIENTE int

BEGIN

select @v_monto = monto ,@V_ID_INTERFAZ = ID_INTERFAZ, @v_ID_CUENTA_CORRIENTE = ID_CUENTA_CORRIENTE  FROM INSERTED

select @v_SALDO = saldo
FROM dbo.CUENTAS_CORRIENTES c
where c.ID_CUENTA_CORRIENTE = @v_ID_CUENTA_CORRIENTE

UPDATE dbo.CUENTAS_CORRIENTES
SET SALDO = @v_SALDO + @v_monto
WHERE ID_CUENTA_CORRIENTE = @v_ID_CUENTA_CORRIENTE


UPDATE m
    SET SALDO = @v_SALDO + @v_monto
    FROM dbo.MOVIMIENTOS_CTACTE M
    INNER JOIN inserted i on i.ID_MOVIMIENTO_CTACTE = M.ID_MOVIMIENTO_CTACTE



UPDATE dbo.INTERFACES
SET
    CANT_OPERACIONES        = CANT_OPERACIONES + 1,
    CANT_ACUM_OPERACIONES    = CANT_ACUM_OPERACIONES + @v_monto
WHERE ID_INTERFAZ =  @V_ID_INTERFAZ


END


/********/</CODE>
</TRIGGER>
</TRIGGERS>
</ENT>
<ENT>
